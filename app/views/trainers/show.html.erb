<div class="container py-4">

  <!-- Trainer profile -->
  <div class="profile-header">
    <% if @trainer.photo.attached? %>
      <%= cl_image_tag @trainer.photo.key %>
    <% end %>
    <div class="profile-info">
      <h1><%= @trainer.name %></h1>
      <p class="profile-meta">Age: <%= @trainer.age %></p>
      <p class="profile-meta"><%= @trainer.pokemons.count %> Pokémon caught</p>
    </div>
  </div>

  <!-- Caught Pokémon -->
  <h2 class="section-title">Caught Pokémon</h2>

  <% if @trainer.pokemons.any? %>
    <div class="row">
      <% @trainer.pokemons.each do |pokemon| %>
        <div class="col-6 col-md-3 mb-4">
          <%= link_to pokemon_path(pokemon), class: "poke-card" do %>
            <% if pokemon.photo.attached? %>
              <%= cl_image_tag pokemon.photo.key %>
            <% end %>
            <span class="poke-name"><%= pokemon.name %></span>
            <span class="type-badge type-<%= pokemon.element_type %>">
              <%= pokemon.element_type %>
            </span>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-muted">No Pokémon caught yet. Time to go exploring! 🌿</p>
  <% end %>

  <%= link_to "← Back to Trainers", trainers_path, class: "btn btn-link" %>
</div>
