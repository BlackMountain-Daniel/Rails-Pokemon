<div class="container py-4">
  <h1 class="page-title">Trainers</h1>

  <div class="row">
    <% @trainers.each do |trainer| %>
      <div class="col-6 col-md-3 mb-4">
        <%= link_to trainer_path(trainer), class: "poke-card" do %>
          <% if trainer.photo.attached? %>
            <%= cl_image_tag trainer.photo.key %>
          <% end %>
          <span class="poke-name"><%= trainer.name %></span>
          <span class="profile-meta">Age <%= trainer.age %></span>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
